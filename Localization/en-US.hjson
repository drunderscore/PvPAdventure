		Tools: {
			DLStartGameTool: {
				DisplayName: Start Game
				AdjustGameTime: Adjust Game Time

				Description: {
					StartGameDescription: Allows you to start the game. Right click to start instantly
					AdjustGameTimeDescription: Allows you to adjust the game time while the game is running.
					CountdownInProgress: A countdown is already in progress!
				}

				RightClickName: DLStartGameTool Right Click
				CannotStart: Cannot start the game while a countdown is in progress
				Time: Time
				Countdown: Countdown
				StartExclamation: Start!
				Apply: Apply
			}

			DLEndGameTool: {
				DisplayName: End Game
				Description: Ends the game timer. Right click to end the game instantly
				ReallyEndGame: Really end game?
				CountdownInProgress: Cannot end the game while a countdown is in progress
				GameNotStartedYet: Game hasn't started yet!
				Yes: Yes
				No: No
				RightClickName: DLEndGameTool Right Click
			}

			DLTeamAssignerTool: {
				DisplayName: Team Assigner
				AssignTeams: Assign Teams
				Description: Assign teams for the game
			}

			DLPauseTool: {
				DisplayName: {
					True: Resume
					False: Pause
				}

				Description: Click to {0} the game
			}

			DLPointsSetterTool: {
				DisplayName: Points Setter
				SetPoints: Set Points
				Description: The tool has no description! Add one in .hjson files!
			}

			DLAdminManagerTool: {
				DisplayName: Admin Manager
				Description: Allows you to manage admin status of all players in the lobby.
				CannotRemoveYourOwnAdminPermissions: Cannot remove your own admin permissions!
			}

			DLOpenConfigTool: {
				DisplayName: {
					Open: Open config
					Close: Close config
				}

				Description: Open PvPAdventure server config
			}
		}

