		Configs: {
			ClientConfig: {
				DisplayName: Adventure Client Config

				Headers: {
					SpawnAndRespawn: "[i:PvPAdventure/MapSpawnConfigItem] Spawn And Respawn"
					Sound: "[i:FairyBell] Sound"
					Movement: "[i:HermesBoots] Movement"
					Chat: "[i:PvPAdventure/ChatConfigItem] Chat"
					Visualization: Visualization
					UI: UI
					Spectating: Spectating
					PortalTravel: Portal Travel
					Vanity: Vanity
				}

				IsVanillaDashEnabled: {
					Label: "[i:PvPAdventure/DashConfigItem] Enable Vanilla Dash"
					Tooltip: Whether double tapping a movement direction will cause a dash
				}

				ShowDebugMessages: {
					Label: Show Debug Messages
					Tooltip:
						'''
						Sends lots of chat messages useful for development flow and debugging.
						Recommended to keep Off for players, On for testers and developers.
						'''
				}

				ShowSavePlayerMessages: {
					Label: Show Save Messages
					Tooltip: Sends a chat message only to you when the player file is saved on the server
				}

				AutoSelectLatestSpawnOption: {
					Label: Auto Select Latest
					Tooltip: Automatically selects the last spawn option used
				}

				ShowChooseYourSpawnText: {
					Label: Show Header
					Tooltip: Shows the 'Choose Your Spawn' header
				}

				SoundEffect: {
					Label: Sound Effect
					Tooltip: ""
				}

				PlayerOutlines: {
					Label: "[i:PvPAdventure/PlayerOutlinesConfigItem] Player Outlines"
					Tooltip: Show outlines around team players
				}

				BedOutlines: {
					Label: "[i:PvPAdventure/BedOutlinesConfigItem] Bed Outlines"
					Tooltip: Show outlines around team beds belonging to a team
				}

				LootOutlines: {
					Label: "[i:PvPAdventure/TreasureBagOutlinesConfigItem] Loot Outlines"
					Tooltip: Show outlines around team boss loot by the team that killed the boss
				}

				ShowVanityVisuals: {
					Label: "[i:245] Show Vanity"
					Tooltip:
						'''
						By default, all your vanity is invisible.
						Turn this on to see your vanity.
						For other players, your armor and accessories is always visible.
						'''
				}

				TabToSwitchChannel: {
					Label: Show Press Tab to Switch
					Tooltip: Shows the toolltip that allows you to press [Tab] to switch between (ALL) and (TEAM) chat
				}

				ShowTeleportPlayerMessages: {
					Label: Show Teleport Messages
					Tooltip: Sends a team message when players use the travel system to teleport
				}

				ShowChatChannelPrefixes: {
					Label: Show Chat Channel Prefixes
					Tooltip: Shows (TEAM) or (ALL) chat channel indicators before chat messages
				}

				ShowCameraFade: {
					Label: Show Camera Fade
					Tooltip: Fades to black when switching camera position to allow for a smoother visual effect
				}

				adventureUIPosition: {
					Label: Adventure UI Position
					Tooltip: ""
				}

				adventureUISize: {
					Label: Adventure UI Size
					Tooltip: ""
				}

				ProjectileOutlines: {
					Label: "[i:PvPAdventure/ProjectileOutlinesConfigItem] Projectile Outlines"
					Tooltip: "Show team outlines around team projectiles by the team shooting the projectiles"
				}

				TownNPCOutlines: {
					Label: "[i:PvPAdventure/TownNPCOutlinesConfigItem] NPC Outlines"
					Tooltip: "Show team outlines around Town NPCs first encountered by a team"
				}
			}

